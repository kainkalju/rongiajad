{
  "expo": {
    "name": "Rongiajad",
    "slug": "rongiajad",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#ff711d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kalju.rongiajad",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Rongiajad kasutab asukohta lähima rongijaama leidmiseks."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ff711d"
      },
      "package": "com.kalju.rongiajad",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Rongiajad kasutab asukohta lähima rongijaama leidmiseks."
        }
      ]
    ]
  }
}
